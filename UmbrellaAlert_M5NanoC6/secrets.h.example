// secrets.h.example
// このファイルを同じフォルダに「secrets.h」という名前でコピーし、
// WiFi資格情報と OpenWeatherMap の APIキーを設定してください。
// secrets.h は .gitignore によりコミットされません（機密をリポジトリに含めないため）。
//
//   1. このファイルを secrets.h にコピー
//   2. 下の値を自分の環境に設定
//
#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID     "your_wifi_ssid"                  // Wi-FiのSSID
#define WIFI_PASSWORD "your_wifi_password"              // Wi-Fiのパスワード
#define API_KEY       "your_openweathermap_api_key_here" // OpenWeatherMap のAPIキー

#endif // SECRETS_H
