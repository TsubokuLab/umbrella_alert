// secrets.h.example
// このファイルを同じフォルダに「secrets.h」という名前でコピーし、
// OpenWeatherMap の APIキーを設定してください。
// secrets.h は .gitignore によりコミットされません。
//
// ※WiFiの資格情報はコードに書かず、初回起動時の設定モード（本体APに接続して
//   ブラウザから設定）で登録します。secrets.h に書く必要はありません。
//
#ifndef SECRETS_H
#define SECRETS_H

#define API_KEY "your_openweathermap_api_key_here"   // OpenWeatherMap のAPIキー

#endif // SECRETS_H
