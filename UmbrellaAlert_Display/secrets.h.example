// secrets.h.example
// このファイルを同じフォルダに「secrets.h」という名前でコピーし、
// OpenWeatherMap の APIキーを設定してください。
// secrets.h は .gitignore によりコミットされません（キーをリポジトリに含めないため）。
//
//   1. このファイルを secrets.h にコピー
//   2. 下の API_KEY に自分のキーを設定
//
#ifndef SECRETS_H
#define SECRETS_H

#define API_KEY "your_openweathermap_api_key_here"   // OpenWeatherMap のAPIキー

#endif // SECRETS_H
